---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { siteData } from "../data/portfolio";
import Layout from "../layouts/Layout.astro";
---

<Layout title={`404 | ${siteData.title}`} description="Page not found.">
	<Header name={siteData.name} resumePath={siteData.resumePath} />

	<main class="not-found">
		<div class="container not-found__inner">
			<p class="not-found__code">404</p>
			<h1 class="not-found__title">Page not found</h1>
			<p class="not-found__message">
				The page you're looking for doesn't exist or has been moved.
			</p>
			<a href="/" class="btn btn-outline">Go home</a>
		</div>
	</main>

	<Footer
		email={siteData.email}
		githubUrl={siteData.githubUrl}
		linkedinUrl={siteData.linkedinUrl}
		resumePath={siteData.resumePath}
		name={siteData.name}
	/>
</Layout>

<style>
	.not-found {
		display: flex;
		align-items: center;
		min-height: calc(100dvh - var(--header-height));
		padding-block: var(--section-gap);
	}

	.not-found__inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}

	.not-found__code {
		font-size: 5rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--text-muted);
	}

	.not-found__title {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.not-found__message {
		color: var(--text-muted);
		font-size: 0.9375rem;
		margin-bottom: 0.5rem;
	}
</style>
