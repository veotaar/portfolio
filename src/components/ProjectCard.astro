---
import ImageCarousel from "./ImageCarousel.astro";
import TagBadge from "./TagBadge.astro";

interface Props {
	name: string;
	tags: string[];
	description: string;
	details: string[];
	images: ImageMetadata[];
	githubUrl: string;
	liveUrl?: string;
	aboveFold?: boolean;
}

const {
	name,
	tags,
	description,
	details,
	images,
	githubUrl,
	liveUrl,
	aboveFold = false,
} = Astro.props;
---

<article class="project-card">
	<div class="project-card__header">
		<h3 class="project-card__name">{name}</h3>
		<div class="project-card__tags">
			{tags.map((tag) => <TagBadge label={tag} />)}
		</div>
		<p class="project-card__description">{description}</p>
	</div>

	{details.length > 0 && (
		<details class="project-card__details">
			<summary class="project-card__expand">
				<span>Show details</span>
				<svg class="project-card__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<polyline points="6 9 12 15 18 9" />
				</svg>
			</summary>
			<ul class="project-card__list">
				{details.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</details>
	)}

	<div class="project-card__actions">
		<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-track="github-click" data-project={name}>
			<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
			</svg>
			GitHub Repo
		</a>
		{liveUrl && (
			<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-track="live-demo-click" data-project={name}>
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
					<polyline points="15 3 21 3 21 9" />
					<line x1="10" y1="14" x2="21" y2="3" />
				</svg>
				Live Demo
			</a>
		)}
	</div>

	<ImageCarousel images={images} projectName={name} aboveFold={aboveFold} />
</article>

<script>
	import { event } from "onedollarstats";

	document.querySelectorAll<HTMLElement>("[data-track]").forEach((el) => {
		el.addEventListener("click", () => {
			const trackEvent = el.dataset.track!;
			if (el.dataset.project) {
				const project = el.dataset.project.toLowerCase().replace(/\s+/g, "-");
				event(trackEvent, `/${project}`, { project });
			} else {
				event(trackEvent);
			}
		});
	});
</script>

<style>
	.project-card {
		background-color: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.project-card__name {
		font-size: 1.375rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.project-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-top: 0.625rem;
	}

	.project-card__description {
		margin-top: 0.75rem;
		color: var(--text-muted);
		font-size: 0.9375rem;
	}

	/* Expandable details */
	.project-card__details {
		border-top: 1px solid var(--border);
		padding-top: 1rem;
	}

	.project-card__expand {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		cursor: pointer;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--text-muted);
		list-style: none;
		user-select: none;
	}

	/* Remove default marker */
	.project-card__expand::-webkit-details-marker {
		display: none;
	}
	.project-card__expand::marker {
		content: "";
	}

	.project-card__chevron {
		transition: transform 0.2s ease;
		flex-shrink: 0;
	}

	.project-card__details[open] .project-card__chevron {
		transform: rotate(180deg);
	}

	.project-card__expand:hover {
		color: var(--text);
	}

	.project-card__list {
		margin-top: 0.75rem;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.project-card__list li {
		list-style: disc;
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	/* Action buttons */
	.project-card__actions {
		display: flex;
		gap: 0.625rem;
		flex-wrap: wrap;
	}
</style>
