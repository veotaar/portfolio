---
import TagBadge from "./TagBadge.astro";

interface Props {
	name: string;
	tags: string[];
	description: string;
	details: string[];
	githubUrl?: string;
	liveUrl?: string;
}

const { name, tags, description, details, githubUrl, liveUrl } = Astro.props;
---

<details class="other-project">
	<summary class="other-project__summary">
		<div class="other-project__header">
			<span class="other-project__name">{name}</span>
			<div class="other-project__tags">
				{tags.map((tag) => <TagBadge label={tag} />)}
			</div>
		</div>
		<svg class="other-project__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polyline points="6 9 12 15 18 9" />
		</svg>
	</summary>
	<div class="other-project__content">
		<p class="other-project__description">{description}</p>
		{details.length > 0 && (
			<ul class="other-project__list">
				{details.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		)}
		{(githubUrl || liveUrl) && (
			<div class="other-project__links">
				{githubUrl && (
					<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
						</svg>
						GitHub
					</a>
				)}
				{liveUrl && (
					<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
							<polyline points="15 3 21 3 21 9" />
							<line x1="10" y1="14" x2="21" y2="3" />
						</svg>
						Live Demo
					</a>
				)}
			</div>
		)}
	</div>
</details>

<style>
	.other-project {
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background-color: var(--bg-surface);
		overflow: hidden;
	}

	.other-project__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
		transition: background-color 0.15s ease;
	}

	.other-project__summary::-webkit-details-marker {
		display: none;
	}
	.other-project__summary::marker {
		content: "";
	}

	.other-project__summary:hover {
		background-color: var(--bg-surface-hover);
	}

	.other-project__header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.other-project__name {
		font-size: 1rem;
		font-weight: 600;
	}

	.other-project__tags {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
	}

	.other-project__chevron {
		flex-shrink: 0;
		color: var(--text-muted);
		transition: transform 0.2s ease;
	}

	.other-project[open] .other-project__chevron {
		transform: rotate(180deg);
	}

	.other-project__content {
		padding: 0 1.25rem 1.25rem;
		border-top: 1px solid var(--border);
	}

	.other-project__description {
		margin-top: 1rem;
		color: var(--text-muted);
		font-size: 0.9375rem;
	}

	.other-project__list {
		margin-top: 0.75rem;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.other-project__list li {
		list-style: disc;
		font-size: 0.875rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	.other-project__links {
		display: flex;
		gap: 0.5rem;
		margin-top: 1rem;
	}
</style>
